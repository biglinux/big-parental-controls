msgid "Apply"
msgstr "Primijeni"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/app_filter_page.py, line: 210
msgid "Failed to update app filter."
msgstr "Neuspješno ažuriranje filtra aplikacije."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/app_filter_page.py, line: 232
msgid "App permissions updated."
msgstr "Ažurirane dozvole aplikacije."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/app_filter_page.py, line: 237
msgid "Failed to apply file permissions."
msgstr "Nije moguće primijeniti dozvole za datoteku."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/time_limits_page.py, line: 51
msgid "Choose when the computer can be used. Outside these hours, this account will be locked."
msgstr "Odaberite kada se računalo može koristiti. Izvan ovih sati, ovaj račun će biti zaključan."
# 
# #-#-#-#-#  big-parental-controls.pot (big-parental-controls)  #-#-#-#-#
