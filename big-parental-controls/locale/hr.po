msgstr "Centar za valorizaciju života — emocionalna podrška putem telefona ili chata"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 22
msgid "Report and get help with online safety issues"
msgstr "Prijavite i zatražite pomoć u vezi s pitanjima online sigurnosti."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 27
msgid "Disque 100"
msgstr "Disk 100"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 28
msgid "Report violations of children's and adolescents' rights"
msgstr "Prijavite kršenja prava djece i adolescenata"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 34
msgid "Internet security guides and best practices"
msgstr "Vodiči za internetsku sigurnost i najbolje prakse"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 65
msgid ""
"If you or someone you know needs help, you are not alone. These organizations provide free, "
"confidential support — no one will judge you."
msgstr ""
"Ako vi ili netko koga poznajete treba pomoć, niste sami. Ove organizacije pružaju besplatnu, "
"povjerljivu podršku — nitko vas neće suditi."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 99
msgid "Emergency"
msgstr "Hitna pomoć"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 102
msgid "In case of immediate danger, call 190 (Police) or 192 (SAMU)"
msgstr "U slučaju neposredne opasnosti, nazovite 190 (Policija) ili 192 (SAMU)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 103
msgid "These numbers are free and available 24/7"
msgstr "Ovi brojevi su besplatni i dostupni 24/7."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 22
msgid "Child (under 10)"
msgstr "Dijete (ispod 10 godina)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 23
msgid "Pre-teen (10–13)"
msgstr "Predteen (10–13)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 24
msgid "Teen (13–16)"
msgstr "Tinejdžer (13–16)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 25
msgid "Young adult (16–18)"
msgstr "Mladi odrasli (16–18)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 70
msgid ""
"Supervised accounts have extra protections to keep children safe. Only a parent or guardian can "
"change these settings."
msgstr ""
"Nadzirani računi imaju dodatne zaštite za sigurnost djece. Samo roditelj ili skrbnik mogu "
"promijeniti ove postavke."
