#
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/app.py, line: 65
#: big-parental-controls/usr/share/biglinux/parental-controls/app.py:65
#, python-format
msgid ""
"This application does not collect, store, or transmit personal data. All "
"processing happens locally on this device. No data is shared with third "
"parties.\n"
"\n"
"Full policy: %s"
msgstr ""
"Questa applicazione non raccoglie, memorizza o trasmette dati personali. "
"Tutto il trattamento avviene localmente su questo dispositivo. Nessun dato "
"viene condiviso con terze parti.\n"
"\n"
"Politica completa: %s"

