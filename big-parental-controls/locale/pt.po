# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 18
msgid "Manage supervised accounts for children"
msgstr "Gerenciar contas supervisionadas para crianças"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 23
msgid "Choose which programs are available"
msgstr "Escolha quais programas estão disponíveis"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 28
msgid "Set daily usage limits"
msgstr "Defina limites de uso diários"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 33
msgid "Block harmful websites automatically"
msgstr "Bloquear sites prejudiciais automaticamente"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 38
msgid "Find support contacts and resources"
msgstr "Encontre contatos de suporte e recursos"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 82
msgid ""
"Keep children safe on this computer. Everything works locally — age range data is shared with other "
"apps on this device via D-Bus to adjust content, but nothing is sent to the internet."
msgstr ""
"Mantenha as crianças seguras neste computador. Tudo funciona localmente — os dados da faixa etária "
"são compartilhados com outros aplicativos neste dispositivo via D-Bus para ajustar o conteúdo, mas "
"nada é enviado para a internet."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 96
msgid "Features"
msgstr "Recursos"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 115
msgid "Your Privacy"
msgstr "Sua Privacidade"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 118
msgid ""
"This application does not collect, store, or transmit personal data. All settings stay on this "
"device. You can read the full privacy policy in the About menu."
msgstr ""
"Este aplicativo não coleta, armazena ou transmite dados pessoais. Todas as configurações permanecem "
"neste dispositivo. Você pode ler a política de privacidade completa no menu Sobre."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 125
msgid "Compliance"
msgstr "Conformidade"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 128
msgid "Follows ECA Digital (Law 15.211/2025), UK Children's Code and EU Digital Services Act"
msgstr ""
"Segue a ECA Digital (Lei 15.211/2025), Código Infantil do Reino Unido e a Lei de Serviços Digitais "
"da UE"
# 
