msgstr "Nødsituasjon"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 102
msgid "In case of immediate danger, call 190 (Police) or 192 (SAMU)"
msgstr "I tilfelle umiddelbar fare, ring 190 (Politi) eller 192 (SAMU)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 103
msgid "These numbers are free and available 24/7"
msgstr "Disse numrene er gratis og tilgjengelige 24/7."
# 
