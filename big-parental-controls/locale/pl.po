msgid "Authentication was cancelled."
msgstr "Autoryzacja została anulowana."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 363
msgid "Helper script not found. Is the package installed correctly?"
msgstr "Nie znaleziono skryptu pomocniczego. Czy pakiet został zainstalowany poprawnie?"
# 
