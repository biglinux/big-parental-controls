msgid "Centro de Valorização da Vida — emotional support by phone or chat"
msgstr "Κέντρο Αξιοποίησης της Ζωής — συναισθηματική υποστήριξη μέσω τηλεφώνου ή συνομιλίας"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 22
msgid "Report and get help with online safety issues"
msgstr "Αναφέρετε και ζητήστε βοήθεια σχετικά με ζητήματα διαδικτυακής ασφάλειας"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 27
msgid "Disque 100"
msgstr "Δίσκος 100"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 28
msgid "Report violations of children's and adolescents' rights"
msgstr "Αναφέρετε παραβιάσεις των δικαιωμάτων των παιδιών και των εφήβων."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 34
msgid "Internet security guides and best practices"
msgstr "Οδηγίες και βέλτιστες πρακτικές για την ασφάλεια του διαδικτύου"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 65
msgid ""
"If you or someone you know needs help, you are not alone. These organizations provide free, "
"confidential support — no one will judge you."
msgstr ""
"Αν εσείς ή κάποιος που γνωρίζετε χρειάζεται βοήθεια, δεν είστε μόνοι. Αυτές οι οργανώσεις παρέχουν "
"δωρεάν, εμπιστευτική υποστήριξη — κανείς δεν θα σας κρίνει."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 99
msgid "Emergency"
msgstr "Έκτακτη ανάγκη"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 102
msgid "In case of immediate danger, call 190 (Police) or 192 (SAMU)"
msgstr "Σε περίπτωση άμεσου κινδύνου, καλέστε το 190 (Αστυνομία) ή το 192 (SAMU)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 103
msgid "These numbers are free and available 24/7"
msgstr "Αυτοί οι αριθμοί είναι δωρεάν και διαθέσιμοι 24/7."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 22
msgid "Child (under 10)"
msgstr "Παιδί (κάτω των 10)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 23
msgid "Pre-teen (10–13)"
msgstr "Προ-έφηβος (10–13)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 24
msgid "Teen (13–16)"
msgstr "Έφηβος (13–16)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 25
msgid "Young adult (16–18)"
msgstr "Νέοι ενήλικες (16–18)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 70
msgid ""
"Supervised accounts have extra protections to keep children safe. Only a parent or guardian can "
"change these settings."
msgstr ""
"Οι εποπτευόμενοι λογαριασμοί έχουν επιπλέον προστασίες για να διατηρούν τα παιδιά ασφαλή. Μόνο ένας "
"γονέας ή κηδεμόνας μπορεί να αλλάξει αυτές τις ρυθμίσεις."
# 
# #-#-#-#-#  big-parental-controls.pot (big-parental-controls)  #-#-#-#-#
# 
# #-#-#-#-#  big-parental-controls.pot (big-parental-controls)  #-#-#-#-#
# 
# #-#-#-#-#  big-parental-controls.pot (big-parental-controls)  #-#-#-#-#
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 84
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/app_filter_page.py, line: 61
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/time_limits_page.py, line: 63
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/dns_page.py, line: 70
msgid "No Supervised Accounts"
msgstr "Χωρίς Εποπτευόμενους Λογαριασμούς"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 86
msgid "Create a supervised account so a child can use this computer safely."
msgstr ""
"Δημιουργήστε έναν εποπτευόμενο λογαριασμό ώστε ένα παιδί να μπορεί να χρησιμοποιεί αυτόν τον "
"υπολογιστή με ασφάλεια."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 139
msgid "Supervised"
msgstr "Επιτηρούμενη"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 142
msgid "Administrator"
msgstr "Διαχειριστής"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 144
msgid "Standard"
msgstr "Πρότυπο"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 161
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 164
msgid "Remove supervised status"
msgstr "Αφαίρεση επιβλεπόμενης κατάστασης"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 176
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 179
msgid "Make supervised"
msgstr "Κάντε επιτηρούμενη"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 195
msgid "Create Supervised Account"
msgstr "Δημιουργία Εποπτευόμενου Λογαριασμού"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 198
msgid ""
"Create a new account with protections for a child or teenager. This account will have safe settings "
"by default."
msgstr ""
"Δημιουργήστε έναν νέο λογαριασμό με προστασίες για ένα παιδί ή έφηβο. Αυτός ο λογαριασμός θα έχει "
"ασφαλείς ρυθμίσεις από προεπιλογή."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 207
msgid "Username"
msgstr "Όνομα χρήστη"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 211
msgid "Full Name"
msgstr "Πλήρες Όνομα"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 214
msgid "Password"
msgstr "Κωδικός πρόσβασης"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 217
msgid "Confirm Password"
msgstr "Επιβεβαίωση Κωδικού Πρόσβασης"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 221
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 293
msgid "Passwords do not match."
msgstr "Οι κωδικοί πρόσβασης δεν ταιριάζουν."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 247
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 527
msgid "Age group"
msgstr "Ηλικιακή ομάδα"
# 
# #-#-#-#-#  big-parental-controls.pot (big-parental-controls)  #-#-#-#-#
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 255
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 472
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 534
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/dns_page.py, line: 172
msgid "Cancel"
msgstr "Ακύρωση"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 256
msgid "Create"
msgstr "Δημιουργία"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 285
msgid "Username and password are required."
msgstr "Απαιτούνται όνομα χρήστη και κωδικός πρόσβασης."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 289
msgid "Username must be 32 characters or less."
msgstr "Το όνομα χρήστη πρέπει να έχει 32 χαρακτήρες ή λιγότερους."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 300
msgid ""
"Username must start with a lowercase letter and contain only letters, numbers, hyphens, and "
"underscores."
msgstr ""
"Το όνομα χρήστη πρέπει να ξεκινά με πεζό γράμμα και να περιέχει μόνο γράμματα, αριθμούς, παύλες και "
"κάτω παύλες."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 308
#, python-format
msgid "A user named '%s' already exists."
msgstr "Ένας χρήστης με το όνομα '%s' υπάρχει ήδη."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 325
msgid "Failed to prepare credentials."
msgstr "Αποτυχία προετοιμασίας διαπιστευτηρίων."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 330
msgid "Creating account…"
msgstr "Δημιουργία λογαριασμού…"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 360
msgid "Authentication was cancelled."
msgstr "Η αυθεντικοποίηση ακυρώθηκε."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 363
msgid "Helper script not found. Is the package installed correctly?"
msgstr "Δεν βρέθηκε το βοηθητικό σενάριο. Είναι εγκατεστημένο σωστά το πακέτο;"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 367
#, python-format
msgid "Exit code %d"
msgstr "Κωδικός εξόδου %d"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 369
#, python-format
msgid "Failed to create user account: %s"
msgstr "Αποτυχία δημιουργίας λογαριασμού χρήστη: %s"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 463
msgid "Remove Supervised Account"
msgstr "Αφαίρεση Εποπτευόμενου Λογαριασμού"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 466
#, python-format
msgid ""
"What would you like to do with %s's account?\n"
"\n"
"• <b>Remove restrictions</b> keeps the account but removes all parental protections.\n"
"• <b>Delete account</b> permanently removes the account and all their files."
msgstr ""
"Τι θα θέλατε να κάνετε με τον λογαριασμό του %s;\n"
"\n"
"• <b>Αφαίρεση περιορισμών</b> διατηρεί τον λογαριασμό αλλά αφαιρεί όλες τις γονικές προστασίες.\n"
"• <b>Διαγραφή λογαριασμού</b> αφαιρεί μόνιμα τον λογαριασμό και όλα τα αρχεία του."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 473
msgid "Remove Restrictions"
msgstr "Αφαίρεση Περιορισμών"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 474
msgid "Delete Account"
msgstr "Διαγραφή Λογαριασμού"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 519
msgid "Add Supervision"
msgstr "Προσθήκη Επίβλεψης"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 521
#, python-format
msgid "Add protections to %s? Installing apps and changing settings will require a parent's permission."
msgstr ""
"Προσθέστε προστασίες στο %s; Η εγκατάσταση εφαρμογών και η αλλαγή ρυθμίσεων θα απαιτούν άδεια από "
"γονέα."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 535
msgid "Add Controls"
msgstr "Προσθήκη Ελέγχων"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/users_page.py, line: 579
msgid "Failed to apply supervised controls."
msgstr "Αποτυχία εφαρμογής επιτηρούμενων ελέγχων."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 18
msgid "Manage supervised accounts for children"
msgstr "Διαχείριση εποπτευόμενων λογαριασμών για παιδιά"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 23
msgid "Choose which programs are available"
msgstr "Επιλέξτε ποια προγράμματα είναι διαθέσιμα"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 28
msgid "Set daily usage limits"
msgstr "Ορίστε ημερήσια όρια χρήσης"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 33
msgid "Block harmful websites automatically"
msgstr "Αυτόματη μπλοκάρισμα επιβλαβών ιστοσελίδων"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 38
msgid "Find support contacts and resources"
msgstr "Βρείτε επαφές υποστήριξης και πόρους"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 82
msgid ""
"Keep children safe on this computer. Everything works locally — age range data is shared with other "
"apps on this device via D-Bus to adjust content, but nothing is sent to the internet."
msgstr ""
"Κρατήστε τα παιδιά ασφαλή σε αυτόν τον υπολογιστή. Όλα λειτουργούν τοπικά — τα δεδομένα ηλικιακής "
"κατηγορίας μοιράζονται με άλλες εφαρμογές σε αυτή τη συσκευή μέσω D-Bus για να προσαρμόσουν το "
"περιεχόμενο, αλλά τίποτα δεν αποστέλλεται στο διαδίκτυο."
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 96
msgid "Features"
msgstr "Χαρακτηριστικά"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 115
msgid "Your Privacy"
msgstr "Η Ιδιωτικότητά σας"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/welcome_page.py, line: 118
msgid ""
"This application does not collect, store, or transmit personal data. All settings stay on this "
"device. You can read the full privacy policy in the About menu."
msgstr ""
"Αυτή η εφαρμογή δεν συλλέγει, αποθηκεύει ή μεταδίδει προσωπικά δεδομένα. Όλες οι ρυθμίσεις "
