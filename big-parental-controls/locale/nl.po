msgstr "In geval van directe gevaar, bel 190 (Politie) of 192 (SAMU)"
# 
# File: big-parental-controls/big-parental-controls/usr/share/biglinux/parental-controls/pages/support_page.py, line: 103
msgid "These numbers are free and available 24/7"
msgstr "Deze nummers zijn gratis en 24/7 beschikbaar."
