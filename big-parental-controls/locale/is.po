#: big-parental-controls/usr/share/biglinux/parental-controls/app.py:65
#, python-format
msgid ""
"This application does not collect, store, or transmit personal data. All "
"processing happens locally on this device. No data is shared with third "
"parties.\n"
"\n"
"Full policy: %s"
msgstr ""
"Þetta forrit safnar ekki, geymir ekki eða sendir ekki persónuupplýsingar. "
"Öll úrvinnsla fer fram á þessu tæki. Engar upplýsingar eru deilt með þriðja "
"aðila.\n"
"\n"
"Heildarstefna: %s"
