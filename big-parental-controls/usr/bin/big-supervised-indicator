#!/usr/bin/env python3
"""System tray indicator for supervised accounts.

Shows a persistent shield icon when the current user belongs to the
supervised group, fulfilling Children's Code Standard 11
(visible signal that monitoring is active).

NOTE: This indicator intentionally uses GTK3 + AppIndicator3 because
there is no GTK4-compatible system tray API. AppIndicator3 implements
the StatusNotifierItem D-Bus protocol and works on both X11 and Wayland
compositors that support SNI (KDE, GNOME with extension, etc).
"""

import grp
import os
import pwd
import signal
import sys

import gi

gi.require_version("AppIndicator3", "0.1")
gi.require_version("Gtk", "3.0")
from gi.repository import AppIndicator3, GLib, Gtk

INDICATOR_ID = "big-supervised-indicator"
SUPERVISED_GROUP = "supervised"
ICON_NAME = "security-high-symbolic"


def is_supervised() -> bool:
    """Check if the current user belongs to supervised group."""
    try:
        group_info = grp.getgrnam(SUPERVISED_GROUP)
    except KeyError:
        return False

    uid = os.getuid()
    username = pwd.getpwuid(uid).pw_name

    # Check supplementary groups
    if username in group_info.gr_mem:
        return True

    # Check primary group
    if pwd.getpwuid(uid).pw_gid == group_info.gr_gid:
        return True

    # Check via os.getgroups()
    return group_info.gr_gid in os.getgroups()


def build_menu() -> Gtk.Menu:
    """Build the indicator context menu."""
    menu = Gtk.Menu()

    # Status header
    status_item = Gtk.MenuItem(label=_("Parental controls are active"))
    status_item.set_sensitive(False)
    menu.append(status_item)

    menu.append(Gtk.SeparatorMenuItem())

    # Info item
    info_item = Gtk.MenuItem(label=_("What does this mean?"))
    info_item.connect("activate", on_info_clicked)
    menu.append(info_item)

    # Help item
    help_item = Gtk.MenuItem(label=_("I need help"))
    help_item.connect("activate", on_help_clicked)
    menu.append(help_item)

    menu.show_all()
    return menu


def on_info_clicked(_widget) -> None:
    """Show explanation dialog about parental controls."""
    dialog = Gtk.MessageDialog(
        message_type=Gtk.MessageType.INFO,
        buttons=Gtk.ButtonsType.OK,
        text=_("Parental controls are active"),
        secondary_text=_(
            "A responsible adult set up protections on this account "
            "to help keep you safe.\n\n"
            "Some apps may be blocked and there may be time limits "
            "for using the computer.\n\n"
            "If you think something is wrong, talk to a trusted adult."
        ),
    )
    dialog.set_title(_("About parental controls"))
    dialog.connect("response", lambda d, _r: d.destroy())
    dialog.show()


def on_help_clicked(_widget) -> None:
    """Open SaferNet help page or show emergency contacts."""
    dialog = Gtk.MessageDialog(
        message_type=Gtk.MessageType.INFO,
        buttons=Gtk.ButtonsType.OK,
        text=_("Need help?"),
        secondary_text=_(
            "Talk to a trusted adult — a parent, teacher, or relative.\n\n"
            "You can also call:\n"
            "• CVV 188 — free emotional support, 24 hours\n"
            "• Disque 100 — report rights violations\n"
            "• SaferNet — safernet.org.br\n\n"
            "These services are free and confidential."
        ),
    )
    dialog.set_title(_("Help"))
    dialog.connect("response", lambda d, _r: d.destroy())
    dialog.show()


def setup_i18n():
    """Set up translations."""
    import gettext
    import locale

    domain = "big-parental-controls"
    locale_dir = "/usr/share/locale"

    try:
        locale.setlocale(locale.LC_ALL, "")
    except locale.Error:
        pass

    locale.bindtextdomain(domain, locale_dir)
    gettext.bindtextdomain(domain, locale_dir)
    gettext.textdomain(domain)

    translation = gettext.translation(domain, localedir=locale_dir, fallback=True)
    return translation.gettext


# i18n
_ = setup_i18n()


def main() -> int:
    if not is_supervised():
        return 0

    # Graceful shutdown on SIGTERM/SIGINT via GLib (proper main loop integration)
    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGINT, Gtk.main_quit)
    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, Gtk.main_quit)

    indicator = AppIndicator3.Indicator.new(
        INDICATOR_ID,
        ICON_NAME,
        AppIndicator3.IndicatorCategory.APPLICATION_STATUS,
    )
    indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
    indicator.set_title(_("Parental controls active"))
    indicator.set_menu(build_menu())

    Gtk.main()
    return 0


if __name__ == "__main__":
    sys.exit(main())
